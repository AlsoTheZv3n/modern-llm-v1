<Window x:Class="ModernLLM.Monitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vm="clr-namespace:ModernLLM.Monitor.ViewModels"
        Title="ModernLLM Monitor"
        Height="640" Width="1000"
        Background="#1E1E1E"
        Foreground="#E0E0E0">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="3,0"/>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Background="#252526" LastChildFill="False" Margin="0">
            <Button Content="Open log…" Click="OpenLog_Click" Margin="6,4"/>
            <Button Content="Reload" Click="Reload_Click" Margin="0,4,6,4"/>
            <Button Content="Sample…" Click="OpenSampler_Click" Margin="0,4,6,4"/>
            <TextBlock Text="{Binding CurrentFile}"
                       VerticalAlignment="Center"
                       Foreground="#AAA"
                       FontFamily="Consolas"
                       Margin="6,0"/>
        </DockPanel>

        <!-- GPU stats row (live from nvidia-smi every 2s) -->
        <Border Grid.Row="1" Background="#2A2A2C" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <Grid Margin="10,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Orientation="Horizontal"
                           Visibility="{Binding GpuAvailable, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource StatLabel}" Text="GPU util"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding GpuUtilPct, StringFormat={}{0}%}"/>
                    <TextBlock Style="{StaticResource StatLabel}" Text="VRAM"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding GpuVramUsedMB, StringFormat={}{0:N0} MB}"/>
                    <TextBlock Style="{StaticResource StatLabel}" Text="/"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding GpuVramTotalMB, StringFormat={}{0:N0} MB}"/>
                    <TextBlock Style="{StaticResource StatLabel}" Text="temp"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding GpuTempC, StringFormat={}{0}°C}"/>
                    <TextBlock Style="{StaticResource StatLabel}" Text="power"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding GpuPowerW, StringFormat={}{0:F0} W}"/>
                </WrapPanel>

                <TextBlock Grid.Column="0"
                           Text="{Binding GpuStatus}"
                           Foreground="#888"
                           FontStyle="Italic"
                           FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GpuAvailable}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- VRAM bar -->
                <Grid Grid.Column="1" Margin="20,2,4,2" VerticalAlignment="Center"
                      Visibility="{Binding GpuAvailable, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Value="{Binding GpuVramUsedMB, Mode=OneWay}"
                                 Maximum="{Binding GpuVramTotalMB, Mode=OneWay}"
                                 Foreground="#3994FF"
                                 Background="#1B1B1C"
                                 BorderBrush="#444"
                                 BorderThickness="1"
                                 Height="14"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Progress header + training stats -->
        <StackPanel Grid.Row="2" Margin="10,8,10,4">

            <!-- Big progress row: Step X / Y  [bar]  ETA -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource StatLabel}" Text="step"/>
                    <TextBlock FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                               Foreground="#E0E0E0" Margin="0,0,2,0"
                               Text="{Binding Step, StringFormat={}{0:N0}}"/>
                    <TextBlock FontFamily="Consolas" FontSize="14" Foreground="#888" Text=" / "/>
                    <TextBox FontFamily="Consolas" FontSize="14" Width="70"
                             Background="#252526" Foreground="#888" BorderBrush="#3C3C3C"
                             BorderThickness="1" Padding="2,0"
                             Text="{Binding TotalSteps, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource StatLabel}" Margin="8,0,4,0" Text="("/>
                    <TextBlock Style="{StaticResource StatValue}" Margin="0"
                               Text="{Binding ProgressPct, StringFormat={}{0:F1}%}"/>
                    <TextBlock Style="{StaticResource StatLabel}" Margin="0,0,8,0" Text=")"/>
                </StackPanel>

                <ProgressBar Grid.Column="1"
                             Value="{Binding ProgressPct, Mode=OneWay}"
                             Maximum="100"
                             Foreground="#5FB85F"
                             Background="#1B1B1C"
                             BorderBrush="#444"
                             BorderThickness="1"
                             Height="18"
                             Margin="12,2"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock FontFamily="Consolas" FontSize="13" Foreground="#E0E0E0"
                               Text="{Binding EtaText}"/>
                </StackPanel>
            </Grid>

            <!-- Throughput + tokens progress -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12"
                           Foreground="#AAA" Text="{Binding ThroughputText}"/>
                <ProgressBar Grid.Column="1"
                             Value="{Binding TokensPct, Mode=OneWay}"
                             Maximum="100"
                             Foreground="#3994FF"
                             Background="#1B1B1C"
                             BorderBrush="#444"
                             BorderThickness="1"
                             Height="10"
                             Margin="12,2"/>
                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12"
                           Foreground="#AAA">
                    <Run Text="{Binding TokensSeen, StringFormat={}{0:N0}, Mode=OneWay}"/>
                    <Run Text=" tok ("/>
                    <Run Text="{Binding TokensPct, StringFormat={}{0:F1}, Mode=OneWay}"/>
                    <Run Text="% of "/>
                    <Run Text="{Binding TotalTokens, StringFormat={}{0:N0}, Mode=OneWay}"/>
                    <Run Text=")"/>
                </TextBlock>
            </Grid>

            <!-- Detail stats line -->
            <WrapPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource StatLabel}" Text="loss"/>
                <TextBlock Style="{StaticResource StatValue}" Text="{Binding Loss, StringFormat={}{0:F4}}"/>

                <TextBlock Style="{StaticResource StatLabel}" Text="last val"/>
                <TextBlock Style="{StaticResource StatValue}" Text="{Binding LastValLoss, StringFormat={}{0:F4}}"/>
                <TextBlock Style="{StaticResource StatLabel}" Text="{Binding LastValAt}"/>

                <TextBlock Style="{StaticResource StatLabel}" Text="lr"/>
                <TextBlock Style="{StaticResource StatValue}" Text="{Binding Lr, StringFormat={}{0:E2}}"/>

                <TextBlock Style="{StaticResource StatLabel}" Text="gnorm"/>
                <TextBlock Style="{StaticResource StatValue}" Text="{Binding GradNorm, StringFormat={}{0:F3}}"/>

                <TextBlock Style="{StaticResource StatLabel}" Text="elapsed"/>
                <TextBlock Style="{StaticResource StatValue}" Text="{Binding ElapsedSec, StringFormat={}{0:F1}s}"/>

                <CheckBox Content="auto-zoom Y" IsChecked="{Binding AutoZoomY}"
                          Foreground="#AAA" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </WrapPanel>
        </StackPanel>

        <!-- Chart -->
        <Border Grid.Row="3" Background="#2D2D30" Margin="10,0">
            <lvc:CartesianChart
                Series="{Binding LossSeries}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"
                AnimationsSpeed="00:00:00.150"
                LegendPosition="Top"
                Margin="6"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding Status}" Margin="10,4" Foreground="#AAA"/>
        </Border>
    </Grid>
</Window>
